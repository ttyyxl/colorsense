rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function canUseDiagnosisFeatures() {
      return request.auth != null
        && (request.auth.token.email_verified == true
          || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    match /diagnoses/{diagnosisId} {
      allow create: if canUseDiagnosisFeatures()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if canUseDiagnosisFeatures()
        && resource.data.userId == request.auth.uid;
    }

    match /community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.userEmail is string
        && request.resource.data.userName is string
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0;
      allow update: if request.auth != null
        && (
          resource.data.uid == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likeCount", "commentCount", "updatedAt"])
        );
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;

      match /likes/{uid} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null
          && request.auth.uid == uid;
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0;
        allow update, delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read, create, update: if canUseDiagnosisFeatures()
        && request.auth.uid == userId;
      allow delete: if false;
    }

    match /users/{userId}/profile/{profileId} {
      allow read, write: if canUseDiagnosisFeatures()
        && request.auth.uid == userId;
    }
  }
}
